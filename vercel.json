{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/check-sla",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/check-sla",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/ward-scoring",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/refresh-matviews",
      "schedule": "0 3 * * 0"
    }
  ]
}
